# ============================================
# LIQUIDPOS 2.0 - VARIABLES DE ENTORNO
# ============================================
# Copia este archivo a .env.local y completa los valores

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=liquidpos

# Para PlanetScale o conexiones SSL:
# DB_SSL=true

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# Genera secrets seguros con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambiar-en-produccion-usar-crypto-randomBytes
NEXTAUTH_SECRET=cambiar-en-produccion-usar-crypto-randomBytes

# URL de la aplicación (cambiar en producción)
NEXTAUTH_URL=http://localhost:3000

# ============================================
# APPLICATION SETTINGS
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NODE_ENV=development

# Nombre de la aplicación
NEXT_PUBLIC_APP_NAME=LiquidPOS

# ============================================
# EMAIL CONFIGURATION (Opcional)
# ============================================
# Necesario para enviar invitaciones a usuarios

# Gmail (requiere "App Password")
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu-app-password

# SendGrid
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=tu-sendgrid-api-key

# Resend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# Email "desde"
SMTP_FROM=noreply@liquidpos.com
SMTP_FROM_NAME=LiquidPOS

# ============================================
# FILE STORAGE (Opcional)
# ============================================
# Necesario para subir imágenes de productos y logos

# Opción 1: Cloudinary (recomendado)
CLOUDINARY_CLOUD_NAME=dihvajnnc
CLOUDINARY_API_KEY=487969716879341
CLOUDINARY_API_SECRET=uqG3LtnVE6M9MRfEbuZWu1SQpqM
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Opción 2: AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=liquidpos-uploads
AWS_CDN_URL=

# Opción 3: Vercel Blob (solo en Vercel)
BLOB_READ_WRITE_TOKEN=

# ============================================
# PAYMENT GATEWAYS (Futuro)
# ============================================
# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# Mercado Pago (para Colombia)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=

# ============================================
# MONITORING & ANALYTICS (Opcional)
# ============================================
# Sentry (error tracking)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Logtail (logs centralizados)
LOGTAIL_SOURCE_TOKEN=

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Vercel Analytics (automático en Vercel)
# No requiere configuración

# ============================================
# SOCIAL LOGIN (OAuth) - Opcional
# ============================================
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================
# EXTERNAL SERVICES (Opcional)
# ============================================
# Twilio (SMS para notificaciones)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Firebase (push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ============================================
# API KEYS (Opcional)
# ============================================
# OpenAI (para features de IA futuros)
OPENAI_API_KEY=

# Google Maps (para ubicaciones)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ============================================
# RATE LIMITING (Producción)
# ============================================
# Upstash Redis (para rate limiting distribuido)
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Límites por defecto
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# SESSION CONFIGURATION
# ============================================
SESSION_MAX_AGE=86400000
SESSION_UPDATE_AGE=3600000

# ============================================
# COMPANY LIMITS (Por defecto - se sobreescribe con planes)
# ============================================
DEFAULT_MAX_COMPANIES=1
DEFAULT_MAX_PRODUCTS=50
DEFAULT_MAX_USERS=1
DEFAULT_MAX_INVOICES=20

# ============================================
# FEATURE FLAGS (Habilitar/deshabilitar features)
# ============================================
ENABLE_CATALOG=true
ENABLE_BARCODE_SCANNER=true
ENABLE_MULTI_LOCATION=true
ENABLE_DISCOUNTS=true
ENABLE_API_ACCESS=false
ENABLE_WEBHOOKS=false

# ============================================
# CRON JOBS (Para limpieza automática)
# ============================================
ENABLE_CRON_JOBS=false
CRON_CLEAN_SESSIONS=0 2 * * *
CRON_CLEAN_LOGS=0 3 * * 0
CRON_SEND_REPORTS=0 8 * * 1

# ============================================
# DEBUG & DEVELOPMENT
# ============================================
# Nivel de logs: error, warn, info, debug
LOG_LEVEL=info

# Habilitar debug de SQL
DEBUG_SQL=false

# Mostrar errores detallados (solo desarrollo)
SHOW_DETAILED_ERRORS=true

# ============================================
# TIMEZONE & LOCALE
# ============================================
TZ=America/Bogota
DEFAULT_LOCALE=es-CO
DEFAULT_CURRENCY=COP

# ============================================
# BACKUP CONFIGURATION
# ============================================
# Ruta para backups automáticos
BACKUP_PATH=/backups
BACKUP_RETENTION_DAYS=7

# ============================================
# NOTAS IMPORTANTES
# ============================================
# 1. NUNCA subas el archivo .env.local a Git
# 2. Agrega .env.local a .gitignore
# 3. En producción, usa variables de entorno del hosting
# 4. Cambia todos los secrets en producción
# 5. Usa HTTPS en producción (NEXTAUTH_URL debe ser https://)